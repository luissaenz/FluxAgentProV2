      "input_schema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "Texto para match exacto o aproximado"
          },
          "options": {
            "type": "object",
            "description": "Filtros en el árbol local"
          }
        },
        "required": [
          "query"
        ]
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "matches": {
            "type": "array",
            "description": "Todos los directorios donde la coincidencia es true"
          }
        }
      },
      "execution": {
        "url": "https://api.dropboxapi.com/2/files/search_v2",
        "method": "POST",
        "headers": {
          "Content-Type": "application/json"
