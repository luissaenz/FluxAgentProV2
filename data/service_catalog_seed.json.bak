      "tool_profile": {
        "description": "Implementa y navega la API de search de Dropbox para localizar extensiones o ficheros específicos ocultos.",
        "example_prompt": "Dime qué documentos en Dropbox contienen la palabra 'Contrato'.",
        "risk_level": "low",
        "requires_approval": false
      }
    },
