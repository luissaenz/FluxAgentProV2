{
  "tools": [
    {
      "id": "activecampaign.add_contact_to_list",
      "name": "Inscribir a Lista ActiveCampaign",
      "provider": {
        "id": "activecampaign",
        "name": "ActiveCampaign",
        "category": "marketing_automation",
        "auth_type": "api_key",
        "base_url": "https://{account_name}.api-us1.com",
        "required_secrets": [
          "activecampaign_api_key"
        ],
        "auth_scopes": []
      },
      "version": "v3",
      "input_schema": {
        "type": "object",
        "properties": {
          "contactList": {
            "type": "object",
            "description": "Debe definir contact (ID), list (ID) y status (1 para activar)",
            "required": [
              "contact",
              "list",
              "status"
            ]
          }
        },
        "required": [
          "contactList"
        ]
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "contactsList": {
            "type": "object",
            "description": "Comprobante de adhesión a la lista"
          }
        }
      },
      "execution": {
        "url": "https://{account_name}.api-us1.com/api/3/contactLists",
        "method": "POST",
        "headers": {
          "Content-Type": "application/json",
          "Api-Token": "{api_key}"
        }
      },
      "tool_profile": {
        "description": "Inyecta un perfil ya pre-creado en ActiveCampaign a un canal o lista de difusión concreta.",
        "example_prompt": "Apúntalo a la lista de 'Compradores recurrentes' (ID 4) de AC.",
        "risk_level": "low",
        "requires_approval": false
      }
    },
    {
      "id": "activecampaign.create_contact",
      "name": "Agregar Contacto a ActiveCampaign",
      "provider": {
        "id": "activecampaign",
        "name": "ActiveCampaign",
        "category": "marketing_automation",
        "auth_type": "api_key",
        "base_url": "https://{account_name}.api-us1.com",
        "required_secrets": [
          "activecampaign_api_key"
        ],
        "auth_scopes": []
      },
      "version": "v3",
      "input_schema": {
        "type": "object",
        "properties": {
          "contact": {
            "type": "object",
            "description": "El objeto principal. Soporta firstName, lastName, phone y email.",
            "required": [
              "email"
            ]
          }
        },
        "required": [
          "contact"
        ]
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "contact": {
            "type": "object",
            "description": "Respuesta con el ID interno asignado"
          }
        }
      },
      "execution": {
        "url": "https://{account_name}.api-us1.com/api/3/contacts",
        "method": "POST",
        "headers": {
          "Content-Type": "application/json",
          "Api-Token": "{api_key}"
        }
      },
      "tool_profile": {
        "description": "Agrega un registro individual de usuario a ActiveCampaign para envíos publicitarios.",
        "example_prompt": "Mete a jose@hotmail.com a nuestra base de ActiveCampaign.",
        "risk_level": "low",
        "requires_approval": false
      }
    },
    {
      "id": "afip.create_invoice_afip",
      "name": "Emitir Factura AFIP",
      "provider": {
        "id": "afip",
        "name": "AFIP",
        "category": "accounting",
        "auth_type": "api_key",
        "base_url": "https://api.afip.gob.ar",
        "required_secrets": [
          "afip_api_key"
        ],
        "auth_scopes": []
      },
      "version": "v1",
      "input_schema": {
        "type": "object",
        "properties": {
          "cuit_emisor": {
            "type": "string",
            "description": "CUIT del emisor"
          },
          "punto_venta": {
            "type": "number",
            "description": "Punto de venta asociado"
          },
          "cbte_tipo": {
            "type": "number",
            "description": "Tipo de comprobante (ej. 11 para Factura C)"
          },
          "doc_tipo": {
            "type": "number",
            "description": "Tipo de documento del cliente (ej. 80 para CUIT, 96 para DNI)"
          },
          "doc_nro": {
            "type": "string",
            "description": "Número de documento o CUIT del cliente"
          },
          "importe_total": {
            "type": "number",
            "description": "Monto total facturado"
          }
        },
        "required": [
          "cuit_emisor",
          "punto_venta",
          "cbte_tipo",
          "doc_tipo",
          "doc_nro",
          "importe_total"
        ]
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "cae": {
            "type": "string",
            "description": "Código de Autorización Electrónico (CAE) otorgado por AFIP"
          },
          "cae_vto": {
            "type": "string",
            "description": "Vencimiento del CAE"
          },
          "comprobante_numero": {
            "type": "number",
            "description": "Número de factura emitido correlativamente"
          }
        }
      },
      "execution": {
        "url": "https://api.afip.gob.ar/wsfev1/factura",
        "method": "POST",
        "headers": {
          "Content-Type": "application/json"
        }
      },
      "tool_profile": {
        "description": "Contacta los web services (WSFEv1) de AFIP para emitir un comprobante fiscal legal (Factura electrónica) obteniendo un CAE en Argentina.",
        "example_prompt": "Emito una Factura C por 15000 pesos al DNI 35000000 desde el punto de venta 3.",
        "risk_level": "high",
        "requires_approval": true
      }
    },
    {
      "id": "afip.get_cae",
      "name": "Consultar CAE Factura AFIP",
      "provider": {
        "id": "afip",
        "name": "AFIP",
        "category": "accounting",
        "auth_type": "api_key",
        "base_url": "https://api.afip.gob.ar",
        "required_secrets": [
          "afip_api_key"
        ],
        "auth_scopes": []
      },
      "version": "v1",
      "input_schema": {
        "type": "object",
        "properties": {
          "punto_venta": {
            "type": "number",
            "description": "Punto de venta emisor"
          },
          "cbte_tipo": {
            "type": "number",
            "description": "Id del tipo de factura (ej. 1=A, 6=B, 11=C)"
          },
          "cbte_nro": {
            "type": "number",
            "description": "Número consecutivo de la factura que se desea chequear"
          }
        },
        "required": [
          "punto_venta",
          "cbte_tipo",
          "cbte_nro"
        ]
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "cae": {
            "type": "string",
            "description": "El CAE de ese comprobante validado"
          },
          "emision_fecha": {
            "type": "string",
            "description": "Día que fue emitido"
          },
          "importe": {
            "type": "number",
            "description": "Valor monetario que fue informado"
          }
        }
      },
      "execution": {
        "url": "https://api.afip.gob.ar/wsfev1/factura/{cbte_nro}/cae?punto_venta={punto_venta}&tipo={cbte_tipo}",
        "method": "GET",
        "headers": {
          "Accept": "application/json"
        }
      },
      "tool_profile": {
        "description": "Verifica si una factura ya fue emitida legalmente ante AFIP recuperando sus datos y su CAE vigente.",
        "example_prompt": "¿Cuál es el CAE y el monto de la Factura C número 104 del punto de venta 2?",
        "risk_level": "low",
        "requires_approval": false
      }
    },
    {
      "id": "afip.validate_cuit",
      "name": "Consultar Padrón CUIT AFIP",
      "provider": {
        "id": "afip",
        "name": "AFIP",
        "category": "accounting",
        "auth_type": "api_key",
        "base_url": "https://api.afip.gob.ar",
        "required_secrets": [
          "afip_api_key"
        ],
        "auth_scopes": []
      },
      "version": "v1",
      "input_schema": {
        "type": "object",
        "properties": {
          "cuit": {
            "type": "string",
            "description": "Identificación tributaria a consultar (ej. 30111111118 sin guiones)"
          }
        },
        "required": [
          "cuit"
        ]
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "nombre": {
            "type": "string",
            "description": "Razón social o Nombre de la persona física"
          },
          "estado": {
            "type": "string",
            "description": "Estado impositivo (ej. ACTIVO)"
          },
          "impuestos": {
            "type": "array",
            "description": "Detalle de IVA, Ganancias, Monotributo, etc."
          }
        }
      },
      "execution": {
        "url": "https://api.afip.gob.ar/ws_sr-padron/v1/persona/{cuit}",
        "method": "GET",
        "headers": {
          "Accept": "application/json"
        }
      },
      "tool_profile": {
        "description": "Permite acceder al padrón alcance 13 de AFIP para verificar la razón social y la situación fiscal (IVA, Monotributo) vinculada a un CUIT.",
        "example_prompt": "Consultá el estado fiscal del CUIT 30-71234567-8 en AFIP.",
        "risk_level": "low",
        "requires_approval": false
      }
    },
    {
      "id": "airtable.create_record",
      "name": "Crear Fila Airtable",
      "provider": {
        "id": "airtable",
        "name": "Airtable",
        "category": "databases",
        "auth_type": "oauth2",
        "base_url": "https://api.airtable.com",
        "required_secrets": [
          "airtable_token"
        ],
        "auth_scopes": [
          "data.records:write"
        ]
      },
      "version": "v0",
      "input_schema": {
        "type": "object",
        "properties": {
          "baseId": {
            "type": "string",
            "description": "El identificador de la base (base ID) de Airtable"
          },
          "tableIdOrName": {
            "type": "string",
            "description": "El nombre o ID de la tabla"
          },
          "records": {
            "type": "array",
            "description": "Matriz de objetos con campos a insertar",
            "items": {
              "type": "object"
            }
          }
        },
        "required": [
          "baseId",
          "tableIdOrName",
          "records"
        ]
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "records": {
            "type": "array",
            "description": "Listado de datos creados en Airtable incluyendo el 'id' único de fila"
          }
        }
      },
      "execution": {
        "url": "https://api.airtable.com/v0/{baseId}/{tableIdOrName}",
        "method": "POST",
        "headers": {
          "Content-Type": "application/json"
        }
      },
      "tool_profile": {
        "description": "Agrega una o más filas (records) nuevos a una base de datos tabular de Airtable.",
        "example_prompt": "Inserta una fila en la Base X Tabla Y de Airtable con el nombre 'María'.",
        "risk_level": "low",
        "requires_approval": false
      }
    },
    {
      "id": "airtable.list_records",
      "name": "List Records",
      "provider": {
        "id": "airtable",
        "name": "Airtable",
        "category": "productivity",
        "auth_type": "api_key",
        "base_url": "https://api.airtable.com/v0",
        "health_check_url": null,
        "docs_url": "https://airtable.com/developers/web/api",
        "required_secrets": [
          "airtable_api_key"
        ]
      },
      "version": "1.0.0",
      "input_schema": {
        "type": "object",
        "properties": {
          "base_id": {
            "type": "string",
            "description": "Airtable base ID"
          },
          "table_name": {
            "type": "string",
            "description": "Table name"
          },
          "maxRecords": {
            "type": "integer",
            "description": "Max records to return"
          }
        },
        "required": [
          "base_id",
          "table_name"
        ]
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "records": {
            "type": "array"
          }
        }
      },
      "execution": {
        "url": "https://api.airtable.com/v0/{base_id}/{table_name}",
        "method": "GET",
        "headers": {}
      },
      "tool_profile": {
        "description": "Lists records from an Airtable table",
        "risk_level": "low",
        "requires_approval": false,
        "category": "productivity"
      }
    },
    {
      "id": "airtable.update_record",
      "name": "Modificar Fila Airtable",
      "provider": {
        "id": "airtable",
        "name": "Airtable",
        "category": "databases",
        "auth_type": "oauth2",
        "base_url": "https://api.airtable.com",
        "required_secrets": [
          "airtable_token"
        ],
        "auth_scopes": [
          "data.records:write"
        ]
      },
      "version": "v0",
      "input_schema": {
        "type": "object",
        "properties": {
          "baseId": {
            "type": "string",
            "description": "Base ID"
          },
          "tableIdOrName": {
            "type": "string",
            "description": "ID de la Tabla"
          },
          "records": {
            "type": "array",
            "description": "Una lista de objetos conteniendo la llave 'id' obligatoria por fila y los 'fields' a alterar."
          }
        },
        "required": [
          "baseId",
          "tableIdOrName",
          "records"
        ]
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "records": {
            "type": "array",
            "description": "Filas confirmadas y consolidadas en Airtable tras el patch"
          }
        }
      },
      "execution": {
        "url": "https://api.airtable.com/v0/{baseId}/{tableIdOrName}",
        "method": "PATCH",
        "headers": {
          "Content-Type": "application/json"
        }
      },
      "tool_profile": {
        "description": "Permite sobrescribir campos en registros de Airtable ya existentes, siempre y cuando se provea el Record ID.",
        "example_prompt": "Actualiza la columna 'Status' de la fila rec123 en Airtable a 'Completado'.",
        "risk_level": "medium",
        "requires_approval": false
      }
    },
