        ],
        "auth_scopes": [
          "meeting:write"
        ]
      },
      "version": "v2",
      "input_schema": {
        "type": "object",
        "properties": {
          "topic": {
            "type": "string",
            "description": "Motivo o título del encuentro"
          },
          "type": {
            "type": "number",
            "description": "Tipo (1 = instantánea, 2 = agendada, 3 = recurrente, 8 = fija)"
          },
          "start_time": {
            "type": "string",
            "description": "Hora de inicio YYYY-MM-DDTHH:MM:SS"
          },
          "duration": {
            "type": "number",
            "description": "Duración de la llamada en minutos"
          }
        },
        "required": [
          "topic",
          "type"
        ]
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number",
            "description": "ID único numérico de la sala Zoom"
          },
          "join_url": {
            "type": "string",
            "description": "El link web de la reunión"
          },
          "password": {
            "type": "string",
            "description": "Código de acceso (passcode)"
          }
        }
      },
      "execution": {
        "url": "https://api.zoom.us/v2/users/me/meetings",
        "method": "POST",
        "headers": {
          "Content-Type": "application/json"
        }
      },
      "tool_profile": {
        "description": "Programa una videollamada y devuelve la invitación y credenciales de Zoom.",
        "example_prompt": "Crea una reunión de Zoom de 45 minutos para el viernes con el equipo de ventas.",
        "risk_level": "low",
        "requires_approval": false
      }
    },
