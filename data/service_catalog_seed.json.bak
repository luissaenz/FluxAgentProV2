    {
      "id": "firestore.create_document",
      "name": "Añadir Documento Firestore",
      "provider": {
        "id": "firebase_firestore",
        "name": "Firebase Firestore",
        "category": "databases",
        "auth_type": "oauth2",
        "base_url": "https://firestore.googleapis.com",
        "required_secrets": [
          "firebase_firestore_token"
        ],
        "auth_scopes": [
          "https://www.googleapis.com/auth/datastore"
        ]
      },
      "version": "v1",
      "input_schema": {
        "type": "object",
        "properties": {
          "projectId": {
            "type": "string",
            "description": "El ID de proyecto GCP / Firebase"
          },
          "collectionId": {
            "type": "string",
            "description": "Ruta de la colección, ej. 'users'"
          },
          "fields": {
            "type": "object",
            "description": "Campos formateados para Firestore (llaves envolviendo valores como stringValue, integerValue)"
          }
        },
        "required": [
          "projectId",
          "collectionId",
          "fields"
        ]
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "URI del documento en Firestore"
          },
          "createTime": {
            "type": "string",
            "description": "Momento de la persistencia"
          }
        }
      },
      "execution": {
        "url": "https://firestore.googleapis.com/v1/projects/{projectId}/databases/(default)/documents/{collectionId}",
        "method": "POST",
        "headers": {
          "Content-Type": "application/json"
        }
      },
      "tool_profile": {
        "description": "Crea una nueva entrada (document) auto-generada en una base de datos NoSQL de Firebase.",
        "example_prompt": "Guarda a este nuevo usuario en la colección 'clientes' de Firestore.",
        "risk_level": "low",
        "requires_approval": false
      }
    },
    {
      "id": "firestore.update_document",
      "name": "Actualizar o Hacer Patch Firestore",
      "provider": {
        "id": "firebase_firestore",
        "name": "Firebase Firestore",
        "category": "databases",
        "auth_type": "oauth2",
        "base_url": "https://firestore.googleapis.com",
        "required_secrets": [
          "firebase_firestore_token"
        ],
        "auth_scopes": [
          "https://www.googleapis.com/auth/datastore"
        ]
      },
      "version": "v1",
      "input_schema": {
        "type": "object",
        "properties": {
          "projectId": {
            "type": "string",
            "description": "ID del proyecto Google"
          },
          "documentPath": {
            "type": "string",
            "description": "Ruta desde la base para encontrar al doc (ej 'users/123xyz')"
          },
          "updateMask": {
            "type": "array",
            "description": "Nombres de los atributos a aplicar o sobrescribir"
          },
          "fields": {
            "type": "object",
            "description": "Estructura anidada con las propiedades nuevas"
          }
        },
        "required": [
          "projectId",
          "documentPath",
          "fields"
        ]
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "updateTime": {
            "type": "string",
            "description": "Timestamp de la operación en Base de Datos"
          }
        }
      },
      "execution": {
        "url": "https://firestore.googleapis.com/v1/projects/{projectId}/databases/(default)/documents/{documentPath}",
        "method": "PATCH",
        "headers": {
          "Content-Type": "application/json"
        }
      },
      "tool_profile": {
        "description": "Permite realizar una escritura parcial sobre un objeto/documento de Firestore existente.",
        "example_prompt": "Cambia el parámetro 'activo' a false para el documento 'users/u_999' de Firestore.",
        "risk_level": "medium",
        "requires_approval": false
      }
    },
